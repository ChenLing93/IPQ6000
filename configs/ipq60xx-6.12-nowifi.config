CONFIG_PACKAGE_luci-i18n-athena-led-zh-cn=m

# ==============================================================================
# 8. 网络工具与代理服务 (Network Tools & Proxy Services)
# ==============================================================================

CONFIG_PACKAGE_miniupnpd-nftables=y   # UPnP 守护进程 (nftables 版)
CONFIG_PACKAGE_mount-utils=y
CONFIG_PACKAGE_opkg=y                 # 包管理器
CONFIG_PACKAGE_resolveip=y
CONFIG_PACKAGE_rpcd=y                 # RPC 守护进程
CONFIG_PACKAGE_rpcd-mod-file=y
CONFIG_PACKAGE_rpcd-mod-iwinfo=y
CONFIG_PACKAGE_rpcd-mod-luci=y
CONFIG_PACKAGE_rpcd-mod-rrdns=y
CONFIG_PACKAGE_rpcd-mod-ucode=y

# 容器运行时组件
CONFIG_PACKAGE_runc=m
CONFIG_PACKAGE_tini=y

# --- 核心代理工具 ---
CONFIG_PACKAGE_sing-box=y             # Sing-Box 全能代理核心
CONFIG_PACKAGE_smartdns=y             # SmartDNS 高性能 DNS
CONFIG_PACKAGE_terminfo=y
CONFIG_PACKAGE_ttyd=y                 # 网页终端后端
CONFIG_PACKAGE_uhttpd=y               # Web 服务器
CONFIG_PACKAGE_uhttpd-mod-ubus=y
CONFIG_PACKAGE_wireguard-tools=y      # WireGuard 工具
CONFIG_PACKAGE_xtables-nft=y

# --- Sing-Box 编译特性 (全功能开启) ---
CONFIG_SING_BOX_BUILD_ACME=y          # ACME 证书支持
CONFIG_SING_BOX_BUILD_CLASH_API=y     # Clash API 兼容
CONFIG_SING_BOX_BUILD_ECH=y           # Encrypted Client Hello
CONFIG_SING_BOX_BUILD_GVISOR=y        # gVisor 沙箱
CONFIG_SING_BOX_BUILD_QUIC=y          # QUIC 协议支持
CONFIG_SING_BOX_BUILD_REALITY_SERVER=y # Reality 服务端支持
CONFIG_SING_BOX_BUILD_UTLS=y          # uTLS 指纹模拟
CONFIG_SING_BOX_BUILD_WIREGUARD=y     # WireGuard 支持

# Ucode 模块 (脚本引擎)
CONFIG_PACKAGE_ucode-mod-html=y
CONFIG_PACKAGE_ucode-mod-lua=y
CONFIG_PACKAGE_ucode-mod-math=y

# ==============================================================================
# 9. 文件系统与构建选项 (Filesystem & Build Options)
# ==============================================================================

# 禁用 initramfs (生成纯 squashfs/ext4 固件)
# CONFIG_TARGET_ROOTFS_INITRAMFS is not set
# 禁用 APK 包格式 (使用 opkg)
# CONFIG_USE_APK is not set

# ==============================================================================
# 10. MbedTLS 加密库定制 (MbedTLS Configuration)
# ==============================================================================
# 针对嵌入式环境优化的加密库配置，启用了现代算法，禁用了过时算法

CONFIG_MBEDTLS_AES_C=y                # AES 加密
# CONFIG_MBEDTLS_ARIA_C is not set
# CONFIG_MBEDTLS_CAMELLIA_C is not set
# CONFIG_MBEDTLS_CCM_C is not set
# CONFIG_MBEDTLS_CIPHER_MODE_OFB is not set
# CONFIG_MBEDTLS_CIPHER_MODE_XTS is not set
CONFIG_MBEDTLS_CMAC_C=y               # CMAC
# CONFIG_MBEDTLS_DEBUG_C is not set
# CONFIG_MBEDTLS_DEPRECATED_WARNING is not set
CONFIG_MBEDTLS_DES_C=y                # DES (兼容旧设备)
# CONFIG_MBEDTLS_ECP_DP_BP256R1_ENABLED is not set
# CONFIG_MBEDTLS_ECP_DP_BP384R1_ENABLED is not set
# CONFIG_MBEDTLS_ECP_DP_BP512R1_ENABLED is not set
CONFIG_MBEDTLS_ECP_DP_CURVE25519_ENABLED=y  # Curve25519 (现代椭圆曲线，WireGuard 使用)
# CONFIG_MBEDTLS_ECP_DP_CURVE448_ENABLED is not set
# CONFIG_MBEDTLS_ECP_DP_SECP192K1_ENABLED is not set
# CONFIG_MBEDTLS_ECP_DP_SECP192R1_ENABLED is not set
# CONFIG_MBEDTLS_ECP_DP_SECP224K1_ENABLED is not set
# CONFIG_MBEDTLS_ECP_DP_SECP224R1_ENABLED is not set
CONFIG_MBEDTLS_ECP_DP_SECP256K1_ENABLED=y
CONFIG_MBEDTLS_ECP_DP_SECP256R1_ENABLED=y
CONFIG_MBEDTLS_ECP_DP_SECP384R1_ENABLED=y
CONFIG_MBEDTLS_ECP_DP_SECP521R1_ENABLED=y
CONFIG_MBEDTLS_ENTROPY_FORCE_SHA256=y
CONFIG_MBEDTLS_GCM_C=y                # GCM 模式 (AES-GCM)
CONFIG_MBEDTLS_HKDF_C=y               # HKDF 密钥派生
# CONFIG_MBEDTLS_KEY_EXCHANGE_DHE_PSK_ENABLED is not set
# CONFIG_MBEDTLS_KEY_EXCHANGE_DHE_RSA_ENABLED is not set
CONFIG_MBEDTLS_KEY_EXCHANGE_ECDHE_ECDSA_ENABLED=y  # ECDHE-ECDSA (TLS 1.2/1.3)
CONFIG_MBEDTLS_KEY_EXCHANGE_ECDHE_PSK_ENABLED=y
CONFIG_MBEDTLS_KEY_EXCHANGE_ECDHE_RSA_ENABLED=y  # ECDHE-RSA
# CONFIG_MBEDTLS_KEY_EXCHANGE_ECDH_ECDSA_ENABLED is not set
# CONFIG_MBEDTLS_KEY_EXCHANGE_ECDH_RSA_ENABLED is not set
CONFIG_MBEDTLS_KEY_EXCHANGE_PSK_ENABLED=y
# CONFIG_MBEDTLS_KEY_EXCHANGE_RSA_ENABLED is not set
# CONFIG_MBEDTLS_KEY_EXCHANGE_RSA_PSK_ENABLED is not set
CONFIG_MBEDTLS_NIST_KW_C=y
# CONFIG_MBEDTLS_PLATFORM_C is not set
CONFIG_MBEDTLS_PSA_CRYPTO_CLIENT=y
# CONFIG_MBEDTLS_RIPEMD160_C is not set
CONFIG_MBEDTLS_RSA_NO_CRT=y
# CONFIG_MBEDTLS_SELF_TEST is not set
CONFIG_MBEDTLS_SSL_PROTO_TLS1_2=y     # 支持 TLS 1.2
CONFIG_MBEDTLS_SSL_PROTO_TLS1_3=y     # 支持 TLS 1.3
# CONFIG_MBEDTLS_SSL_RENEGOTIATION is not set
CONFIG_MBEDTLS_SSL_TLS1_3_COMPATIBILITY_MODE=y
CONFIG_MBEDTLS_SSL_TLS1_3_KEY_EXCHANGE_MODE_EPHEMERAL_ENABLED=y
CONFIG_MBEDTLS_SSL_TLS1_3_KEY_EXCHANGE_MODE_PSK_ENABLED=y
CONFIG_MBEDTLS_SSL_TLS1_3_KEY_EXCHANGE_MODE_PSK_EPHEMERAL_ENABLED=y
CONFIG_MBEDTLS_THREADING_C=y          # 多线程支持
CONFIG_MBEDTLS_THREADING_PTHREAD=y
# CONFIG_MBEDTLS_VERSION_C is not set
# CONFIG_MBEDTLS_VERSION_FEATURES is not set

# 将 libmbedtls 编译为模块以节省空间 (如果需要)
CONFIG_PACKAGE_libmbedtls=m
