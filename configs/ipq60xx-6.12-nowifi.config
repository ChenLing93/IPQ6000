# 启用 Qualcomm IPQ60xx 系列平台支持 (高通 Wi-Fi 6 路由器芯片)
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y

# 启用多设备配置文件支持 (允许一个固件镜像支持多种设备型号)
CONFIG_TARGET_MULTI_PROFILE=y

# --- 具体支持的设备列表 ---
# AnySafe E1
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_anysafe_e1=y
# CMIOT AX18
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_cmiot_ax18=y
# GL.iNet Flint (AX1800)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_glinet_gl-ax1800=y
# GL.iNet Slate AX (AXT1800)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_glinet_gl-axt1800=y
# 京东云 无线宝 RE-SS-01 (第一代)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01=y
# 京东云 无线宝 雅典娜 RE-CS-02 (重点优化设备)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02=y
# 为京东云 RE-CS-02 预装特定的 LED 控制插件和中文语言包
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02="luci-app-athena-led luci-i18n-athena-led-zh-cn"
# 京东云 无线宝 RE-CS-07
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-07=y
# 联芸 NN6000 v1 版本
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_link_nn6000-v1=y
# 联芸 NN6000 v2 版本
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_link_nn6000-v2=y
# 360 安全路由器 V6
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_qihoo_360v6=y
# 红米 AX5
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_redmi_ax5=y
# 小米 AX1800
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_xiaomi_ax1800=y
# ZN M2
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_zn_m2=y

# 禁用 Ath11k NSS 支持 (可能为了兼容性或特定驱动版本)
# CONFIG_ATH11K_NSS_SUPPORT is not set

# ==============================================================================
# 2. 系统性能与基准测试优化 (System Performance & Benchmarking)
# ==============================================================================

# 启用 Coremark 基准测试的多线程支持
CONFIG_COREMARK_ENABLE_MULTITHREADING=y
# 设置 Coremark 线程数为 16 (IPQ60xx 通常为 4 核 8 线程或类似，此处设为 16 可能是为了极限压测)
CONFIG_COREMARK_NUMBER_OF_THREADS=16
# 启用 O3 最高级别编译优化，提升运行速度
CONFIG_COREMARK_OPTIMIZE_O3=y

# ==============================================================================
# 3. Docker 容器支持 (Docker Container Support)
# ==============================================================================
# 注意：Docker 会显著增加内存和存储消耗，建议设备内存 >= 512MB

# 启用 Docker 的 Cgroup 选项
CONFIG_DOCKER_CGROUP_OPTIONS=y
# 启用 Docker Macvlan 网络模式 (用于让容器拥有独立局域网 IP)
CONFIG_DOCKER_NET_MACVLAN=y
# 启用 Docker 可选功能集
CONFIG_DOCKER_OPTIONAL_FEATURES=y
# 启用 Docker 存储驱动扩展支持 (ext4)
CONFIG_DOCKER_STO_EXT4=y

# ==============================================================================
# 4. 无线驱动与内核配置 (Wireless Drivers & Kernel Config)
# ==============================================================================

# 禁用旧版 802.11ac 驱动支持 (专注于 Wi-Fi 6/AX)
# CONFIG_DRIVER_11AC_SUPPORT is not set
# 禁用 802.11ax 驱动支持 (此处被禁用，可能依赖 NSS 或其他内置驱动，需留意 Wi-Fi 是否正常)
# CONFIG_DRIVER_11AX_SUPPORT is not set

# 启用 htop 的 lm-sensors 支持 (硬件监控)
CONFIG_HTOP_LMSENSORS=y

# --- 内核高级特性 ---
CONFIG_KERNEL_ARM_PMU=y                      # ARM 性能监控单元
CONFIG_KERNEL_CFQ_GROUP_IOSCHED=y            # CFQ 组 I/O 调度器
CONFIG_KERNEL_CGROUP_DEVICE=y                # Cgroup 设备控制
CONFIG_KERNEL_CGROUP_FREEZER=y               # Cgroup 冻结进程
CONFIG_KERNEL_CGROUP_HUGETLB=y               # Cgroup 大页支持
CONFIG_KERNEL_CGROUP_NET_PRIO=y              # Cgroup 网络优先级
CONFIG_KERNEL_CGROUP_PERF=y                  # Cgroup 性能事件
CONFIG_KERNEL_HUGETLBFS=y                    # 大页文件系统
CONFIG_KERNEL_HUGETLB_PAGE=y                 # 大页内存支持
CONFIG_KERNEL_MEMCG_SWAP_ENABLED=y           # 内存 Cgroup 交换支持
CONFIG_KERNEL_NET_CLS_CGROUP=y               # 网络分类 Cgroup
CONFIG_KERNEL_PERF_EVENTS=y                  # 性能事件
# CONFIG_KERNEL_PREEMPT_RCU is not set       # 禁用 RCU 抢占 (可能为了稳定性)
CONFIG_KERNEL_TRANSPARENT_HUGEPAGE=y         # 透明大页支持
CONFIG_KERNEL_TRANSPARENT_HUGEPAGE_ALWAYS=y  # 始终启用透明大页 (提升大内存应用性能)

# ==============================================================================
# 5. 本地化与 NSS 硬件加速 (Localization & NSS Acceleration)
# ==============================================================================

# 设置 LuCI 界面默认语言为简体中文
CONFIG_LUCI_LANG_zh_Hans=y

# --- Qualcomm NSS (Network Security Subsystem) 硬件加速驱动 ---
CONFIG_NSS_DRV_IGS_ENABLE=y          # 智能网关服务加速
CONFIG_NSS_DRV_MAPT_ENABLE=y         # MAP-T (IPv6 过渡技术) 加速
CONFIG_NSS_DRV_PPTP_ENABLE=y         # PPTP 协议加速
CONFIG_NSS_DRV_SHAPER_ENABLE=y       # 流量整形加速
# CONFIG_NSS_DRV_WIFIOFFLOAD_ENABLE is not set  # 禁用 Wi-Fi 卸载 (Wi-Fi 数据可能走 CPU)

# NSS 固件版本选择 (使用 12.2 版本)
CONFIG_NSS_FIRMWARE_VERSION_12_2=y
# CONFIG_NSS_FIRMWARE_VERSION_12_5 is not set

# ==============================================================================
# 6. 软件包管理与其他工具 (Package Management & Utilities)
# ==============================================================================

# 使用 curl 作为 opkg 的后端下载工具
CONFIG_OPKG_USE_CURL=y

# 禁用 APK 包管理器相关的 mbedTLS/OpenSSL (使用系统默认的)
# CONFIG_PACKAGE_apk-mbedtls is not set
# CONFIG_PACKAGE_apk-openssl is not set

# 禁用独立的 ath11k 固件包 (可能已集成在内核或目标文件中)
# CONFIG_PACKAGE_ath11k-firmware-ipq6018 is not set
# CONFIG_PACKAGE_ath11k-firmware-qcn9074 is not set

# 启用 Btrfs 文件系统工具 (高级文件系统，支持快照/压缩)
CONFIG_PACKAGE_btrfs-progs=y
# 启用 CA 证书包 (HTTPS 校验必需)
CONFIG_PACKAGE_ca-certificates=y
# 启用 CGI IO 支持
CONFIG_PACKAGE_cgi-io=y
# 启用 Cgroup 文件系统挂载工具
CONFIG_PACKAGE_cgroupfs-mount=y
# 启用 ChinaDNS-NG (DNS 分流/抗污染)
CONFIG_PACKAGE_chinadns-ng=y

# --- Docker 核心组件 ---
CONFIG_PACKAGE_containerd=m          # 容器运行时 (模块)
CONFIG_PACKAGE_docker=m              # Docker 引擎 (模块)
CONFIG_PACKAGE_docker-compose=m      # Docker 编排工具 (模块)
CONFIG_PACKAGE_dockerd=m             # Docker 守护进程 (模块)

# 启用 Coremark 跑分工具
CONFIG_PACKAGE_coremark=y
# 启用默认设置 (中国区优化)
CONFIG_PACKAGE_default-settings=y
CONFIG_PACKAGE_default-settings-chn=y
# 启用 Etherwake (网络唤醒)
CONFIG_PACKAGE_etherwake=y

# 禁用 hostapd-common (可能使用其他版本或内置)
# CONFIG_PACKAGE_hostapd-common is not set

# 启用 htop (进程监控)
CONFIG_PACKAGE_htop=y
# 启用精简版 ip 工具
CONFIG_PACKAGE_ip-tiny=y
# 启用 nftables 版的 ip6tables
CONFIG_PACKAGE_ip6tables-nft=y

# --- 禁用特定设备的 Wi-Fi 校准数据包 ---
# 注意：如果刷入后 Wi-Fi 无法启动，可能需要取消以下某一项的注释，取决于你的具体设备型号
# CONFIG_PACKAGE_ipq-wifi-cmiot_ax18 is not set
# CONFIG_PACKAGE_ipq-wifi-jdcloud_re-cs-02 is not set
# CONFIG_PACKAGE_ipq-wifi-jdcloud_re-ss-01 is not set
# CONFIG_PACKAGE_ipq-wifi-qihoo_v6 is not set
# CONFIG_PACKAGE_ipq-wifi-redmi_ax5 is not set
# CONFIG_PACKAGE_ipq-wifi-redmi_ax5-jdcloud is not set
# CONFIG_PACKAGE_ipq-wifi-xiaomi_ax1800 is not set
# CONFIG_PACKAGE_ipq-wifi-zn_m2 is not set

# 启用 iptables 扩展模块
CONFIG_PACKAGE_iptables-mod-extra=y
# 启用 nftables 版的 iptables
CONFIG_PACKAGE_iptables-nft=y
# 禁用 iw (使用其他工具替代)
# CONFIG_PACKAGE_iw is not set

# --- 内核模块 (Kernel Modules) ---
# 禁用部分通用 ath 驱动，使用高通专用驱动
# CONFIG_PACKAGE_kmod-ath is not set
# CONFIG_PACKAGE_kmod-ath11k is not set
# CONFIG_PACKAGE_kmod-ath11k-ahb is not set
# CONFIG_PACKAGE_kmod-ath11k-pci is not set

CONFIG_PACKAGE_kmod-br-netfilter=y   # 网桥 netfilter 支持 (Docker 必需)
# CONFIG_PACKAGE_kmod-cfg80211 is not set
CONFIG_PACKAGE_kmod-crypto-acompress=y # 加密压缩
CONFIG_PACKAGE_kmod-crypto-blake2b=y   # Blake2b 哈希
CONFIG_PACKAGE_kmod-crypto-kpp=y       # 密钥对协议
CONFIG_PACKAGE_kmod-crypto-lib-chacha20=y
CONFIG_PACKAGE_kmod-crypto-lib-chacha20poly1305=y
CONFIG_PACKAGE_kmod-crypto-lib-curve25519=y
CONFIG_PACKAGE_kmod-crypto-lib-poly1305=y
CONFIG_PACKAGE_kmod-crypto-xxhash=y

CONFIG_PACKAGE_kmod-dummy=y          # 虚拟网卡驱动
CONFIG_PACKAGE_kmod-fs-btrfs=y       # Btrfs 文件系统驱动
CONFIG_PACKAGE_kmod-ifb=y            # 中间功能块 (流量控制)
CONFIG_PACKAGE_kmod-inet-diag=y      # 网络诊断
CONFIG_PACKAGE_kmod-ip6tables=y
CONFIG_PACKAGE_kmod-ipt-conntrack=y  # 连接追踪
CONFIG_PACKAGE_kmod-ipt-core=y
CONFIG_PACKAGE_kmod-ipt-extra=y
CONFIG_PACKAGE_kmod-ipt-nat=y        # NAT
CONFIG_PACKAGE_kmod-ipt-nat6=y
CONFIG_PACKAGE_kmod-ipt-physdev=y
CONFIG_PACKAGE_kmod-lib-lzo=y
CONFIG_PACKAGE_kmod-lib-raid6=y
CONFIG_PACKAGE_kmod-lib-xor=y
CONFIG_PACKAGE_kmod-lib-xxhash=y
CONFIG_PACKAGE_kmod-lib-zlib-deflate=y
CONFIG_PACKAGE_kmod-lib-zlib-inflate=y
CONFIG_PACKAGE_kmod-lib-zstd=y       # Zstd 压缩

# CONFIG_PACKAGE_kmod-mac80211 is not set
CONFIG_PACKAGE_kmod-macvlan=y        # Macvlan 驱动 (Docker 网络必需)
CONFIG_PACKAGE_kmod-nat46=y
CONFIG_PACKAGE_kmod-netlink-diag=y
CONFIG_PACKAGE_kmod-nf-ipt=y
CONFIG_PACKAGE_kmod-nf-ipt6=y
CONFIG_PACKAGE_kmod-nf-ipvs=y        # IPVS (负载均衡)
CONFIG_PACKAGE_kmod-nf-nat6=y
CONFIG_PACKAGE_kmod-nf-tproxy=y      # TProxy (透明代理必需)
CONFIG_PACKAGE_kmod-nft-compat=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-qca-mcs=y        # 高通 MCS 支持
CONFIG_PACKAGE_kmod-qca-nss-drv-igs=y
CONFIG_PACKAGE_kmod-qca-nss-drv-map-t=y
CONFIG_PACKAGE_kmod-qca-nss-drv-pppoe=y
CONFIG_PACKAGE_kmod-qca-nss-drv-pptp=y
CONFIG_PACKAGE_kmod-qca-nss-drv-qdisc=y
CONFIG_PACKAGE_kmod-qca-nss-macsec=y

CONFIG_PACKAGE_kmod-sched-core=y     # 流量调度核心
CONFIG_PACKAGE_kmod-scsi-core=y
CONFIG_PACKAGE_kmod-tun=y            # TUN/TAP 驱动 (WireGuard/OpenVPN 必需)
CONFIG_PACKAGE_kmod-usb-dwc2=y       # USB DRD 控制器
CONFIG_PACKAGE_kmod-usb-dwc2-pci=y
CONFIG_PACKAGE_kmod-usb-dwc3=y
CONFIG_PACKAGE_kmod-usb-dwc3-qcom=y
CONFIG_PACKAGE_kmod-usb-ehci=y       # USB 2.0 EHCI
CONFIG_PACKAGE_kmod-usb-ohci=y       # USB 1.1 OHCI
CONFIG_PACKAGE_kmod-usb-xhci-hcd=y
CONFIG_PACKAGE_kmod-usb-phy-nop=y
CONFIG_PACKAGE_kmod-usb-roles=y
CONFIG_PACKAGE_kmod-usb-storage=y    # USB 存储
CONFIG_PACKAGE_kmod-usb-storage-extras=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-usb-uhci=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb2-pci=y
CONFIG_PACKAGE_kmod-veth=y           # 虚拟以太网对 (Docker 必需)
CONFIG_PACKAGE_kmod-wireguard=y      # WireGuard 驱动


# ==============================================================================
# 7. 库文件与 LuCI 界面 (Libraries & LuCI UI)
# ==============================================================================

# 基础库
CONFIG_PACKAGE_libattr=y
CONFIG_PACKAGE_libcap=y
CONFIG_PACKAGE_libcap-ng=y
CONFIG_PACKAGE_libiptext=y
CONFIG_PACKAGE_libiptext-nft=y
CONFIG_PACKAGE_libiptext6=y
CONFIG_PACKAGE_liblua=y
CONFIG_PACKAGE_liblucihttp=y
CONFIG_PACKAGE_liblucihttp-lua=y
CONFIG_PACKAGE_liblucihttp-ucode=y
CONFIG_PACKAGE_liblzo=y
CONFIG_PACKAGE_libmount=y
CONFIG_PACKAGE_libncurses=y
CONFIG_PACKAGE_libseccomp=y          # 安全计算模式 (Docker 安全必需)
CONFIG_PACKAGE_libubus-lua=y
CONFIG_PACKAGE_libuv=y
CONFIG_PACKAGE_libwebsockets-full=y
CONFIG_PACKAGE_libxtables=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_fdisk=y 
CONFIG_PACKAGE_block-mount=y  
# Lua 解释器
CONFIG_PACKAGE_lua=y

# --- LuCI 核心与主题 ---
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-app-argon-config=y       # Argon 主题配置插件
CONFIG_PACKAGE_luci-app-dockerman=m          # Docker 管理界面 (模块)
CONFIG_PACKAGE_luci-app-firewall=y           # 防火墙配置
CONFIG_PACKAGE_luci-app-homeproxy=y          # HomeProxy 代理插件 (支持 Sing-Box/Xray)
CONFIG_PACKAGE_luci-app-package-manager=y    # 包管理器界面
CONFIG_PACKAGE_luci-app-smartdns=y           # SmartDNS 配置界面
CONFIG_PACKAGE_luci-app-ttyd=y               # 网页终端
CONFIG_PACKAGE_luci-app-upnp=y               # UPnP 配置
CONFIG_PACKAGE_luci-app-wol=y                # 网络唤醒
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-light=y
CONFIG_PACKAGE_luci-lua-runtime=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-mod-network=y
CONFIG_PACKAGE_luci-mod-status=y
CONFIG_PACKAGE_luci-mod-system=y
CONFIG_PACKAGE_luci-proto-ipv6=y
CONFIG_PACKAGE_luci-proto-ppp=y
CONFIG_PACKAGE_luci-proto-wireguard=y
CONFIG_PACKAGE_luci-theme-argon=y            # Argon 主题
CONFIG_PACKAGE_luci-theme-bootstrap=y

# --- LuCI 国际化 (中文) ---
CONFIG_PACKAGE_luci-i18n-argon-config-zh-cn=y
